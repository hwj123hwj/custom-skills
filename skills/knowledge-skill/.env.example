# 数据库（PostgreSQL）
DB_HOST=你的服务器IP
DB_PORT=5433
DB_USER=bili
DB_PASSWORD=你的密码
DB_NAME=bilibili

# SiliconFlow API (Embedding + ASR)
SILICONFLOW_API_KEY=sk-xxx

# 龙猫 API (AI 摘要，免费)
LONGCAT_API_KEY=ak-xxx

# 模型配置
EMBEDDING_MODEL=BAAI/bge-m3
ASR_MODEL=TeleAI/TeleSpeechASR

# 代理（可选）
HTTP_PROXY=http://127.0.0.1:7890

# 飞书知识库发布（机器人 / Agent 后端使用）
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=你的应用密钥
# 推荐：直接填目标 Wiki 页面 URL，脚本会自动解析 space_id 和 parent node
FEISHU_TARGET_URL=https://example.feishu.cn/wiki/wikcn_xxx
FEISHU_TARGET_SPACE_ID=spc_xxx
# 可选：目标 Wiki 父页面 node_token
FEISHU_TARGET_PARENT_TOKEN=wikcn_xxx
# 可选：私有化 / Lark 国际版时覆盖 OpenAPI 地址
FEISHU_OPENAPI_BASE_URL=https://open.feishu.cn

# Cookie 文件路径
XHS_COOKIE_PATH=~/.xiaohongshu-cli/cookies.json
BILI_CREDENTIAL_PATH=~/.bilibili-cli/credential.json
